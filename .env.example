# =============================================
# Browserless 환경 설정
# =============================================
# 이 파일을 .env로 복사하고 값을 설정하세요
# cp .env.example .env

# === 필수: 인증 토큰 ===
# 아래 명령어로 생성:
# openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
# 또는 PowerShell:
# -join ((1..32) | ForEach-Object { [char](Get-Random -Minimum 65 -Maximum 123 | Where-Object { $_ -lt 91 -or $_ -gt 96 }) })
BROWSERLESS_TOKEN=YOUR_SECURE_TOKEN_HERE

# === 성능 설정 ===
CONCURRENT=5           # 동시 브라우저 세션 수
QUEUED=10              # 대기열 크기
TIMEOUT=60000          # 세션 타임아웃 (밀리초)

# === 리소스 제한 ===
MAX_CPU=80             # CPU 사용률 제한 (%)
MAX_MEMORY=80          # 메모리 사용률 제한 (%)

# === 외부 접속 URL (Tailscale) ===
# n8n/Activepieces에서 접속할 URL
# 예: http://desktop.tail12345.ts.net:3000
# 또는 Tailscale IP: http://100.x.x.x:3000
EXTERNAL_URL=

# =============================================
# n8n/Activepieces 연결 정보
# =============================================
# 
# WebSocket URL (Puppeteer/Playwright 연결):
#   ws://[TAILSCALE_IP]:3000?token=YOUR_TOKEN
#   ws://[TAILSCALE_IP]:3000/chromium?token=YOUR_TOKEN
#
# HTTP URL (REST API):
#   http://[TAILSCALE_IP]:3000?token=YOUR_TOKEN
#
# 예시:
#   ws://100.64.0.10:3000?token=abc123def456
#   ws://desktop.tail12345.ts.net:3000?token=abc123def456
# =============================================
